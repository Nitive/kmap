[Service]
WorkingDirectory=/
ExecStart=/home/nitive/Develop/keyboard/altremap-start.sh
Restart=always
RestartSec=3
Nice=-20
User=nitive
Group=input
Environment="XDG_RUNTIME_DIR=/run/user/1000"
Environment="WAYLAND_DISPLAY=wayland-0"
Environment="KEYBOARD_DEVICE=/dev/input/by-id/usb-04d9_USB-HID_Keyboard-event-kbd"

[Install]
WantedBy=multi-user.target
